[Unit]
Description=Bybit Trading Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/bybit_bot
ExecStart=/root/bybit_bot/.venv/bin/python -m bot.main
Restart=always
RestartSec=10
StandardOutput=append:/root/bybit_bot/logs/run.log
StandardError=append:/root/bybit_bot/logs/run.log

# Graceful shutdown timeout
TimeoutStopSec=30

# Environment
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
